# 服务端口
PORT=3001

# JWT 密钥(必填,随机长字符串)
JWT_SECRET=change-this-to-a-random-long-string

# 单用户账号(必填)
USER_PHONE=13800138000
# bcrypt hash of "password" —— 可用 node -e "console.log(require('bcryptjs').hashSync('password',10))" 生成
# 这里默认占位 "password" 的 hash
USER_PASSWORD=$2b$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy

# Ozon OPI(官方 API 跟卖用,可选)
OZON_OPI_BASE_URL=https://api-seller.ozon.ru

# 日志级别: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# ── 数据库驱动配置 ────────────────────────────────────────
# 缓存/采集日志/店铺分类/采集队列 的存储驱动
# - sqlite: 使用 SQLite(默认,零依赖,数据文件在 data/erp.db)
# - mongo:  使用 MongoDB(需配置 MONGO_* 参数)
DB_DRIVER=sqlite

# MongoDB 配置(仅 DB_DRIVER=mongo 时生效)
MONGO_HOST=
MONGO_PORT=27017
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

