{
  "manifest_version": 3,
  "name": "QX",
  "version": "0.13.31.1",
  "description": "QX Ozon",
  "permissions": [
    "storage",
    "contextMenus",
    "alarms",
    "cookies",
    "scripting",
    "notifications",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.ozon.ru/*",
    "https://www.ozon.ru/*",
    "https://ozon.ru/*",
    "https://seller.ozon.ru/*",
    "https://api-seller.ozon.ru/*",
    "https://*.ozone.ru/*",
    "https://*.ozonusercontent.com/*",
    "*://*.ozon.kz/*",
    "https://ozon.kz/*",
    "http://localhost:3000/*",
    "http://store.localhost:3000/*",
    "http://localhost:3001/*",
    "https://open.er-api.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "QX"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ozon.ru/product/*",
        "https://ozon.kz/product/*",
        "https://*.ozon.kz/product/*",
        "https://www.ozon.ru/category/*",
        "https://www.ozon.ru/search/*",
        "https://www.ozon.ru/search-by-image*",
        "https://ozon.kz/category/*",
        "https://ozon.kz/search/*",
        "https://ozon.kz/search-by-image*",
        "https://*.ozon.kz/category/*",
        "https://*.ozon.kz/search/*",
        "https://*.ozon.kz/search-by-image*"
      ],
      "js": [
        "content/ozon-bff-interceptor.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.ozon.ru/*",
        "https://ozon.ru/*",
        "https://ozon.kz/*",
        "https://*.ozon.kz/*"
      ],
      "js": [
        "content/shared-utils.js",
        "content/jzc-calc.js",
        "content/collector/db.js",
        "content/collector/l1-shadow-db.js",
        "content/collector/l1-bridge.js",
        "content/collector/l1-diff.js",
        "lib/cdn-buster.js",
        "lib/watermark-templates.js",
        "lib/follow-sell-content-copy.js",
        "lib/ozon-video-extract.js",
        "lib/sku-collect.js",
        "lib/title-quality.js",
        "content/ozon-product.js"
      ],
      "css": [
        "content/jzc-calc.css",
        "content/ozon-product.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ozon.ru/category/*",
        "https://www.ozon.ru/search/*",
        "https://www.ozon.ru/search-by-image*",
        "https://ozon.kz/category/*",
        "https://ozon.kz/search/*",
        "https://ozon.kz/search-by-image*",
        "https://*.ozon.kz/category/*",
        "https://*.ozon.kz/search/*",
        "https://*.ozon.kz/search-by-image*"
      ],
      "js": [
        "content/shared-utils.js",
        "content/collector/task-queue.js",
        "content/collector/db.js",
        "content/collector/l1-shadow-db.js",
        "content/collector/l1-bridge.js",
        "content/collector/l1-diff.js",
        "content/collector/auto-scroller.js",
        "content/collector/keyword-pilot.js",
        "content/collector/anti-ban.js",
        "content/collector/panel.js",
        "lib/sidebar-section-toggle.js",
        "content/ozon-search.js"
      ],
      "css": [
        "content/ozon-product.css",
        "content/ozon-search.css",
        "content/collector/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ozon.ru/*",
        "https://ozon.kz/*",
        "https://*.ozon.kz/*"
      ],
      "exclude_matches": [
        "https://www.ozon.ru/category/*",
        "https://www.ozon.ru/search/*",
        "https://www.ozon.ru/search-by-image*",
        "https://ozon.kz/category/*",
        "https://ozon.kz/search/*",
        "https://ozon.kz/search-by-image*",
        "https://*.ozon.kz/category/*",
        "https://*.ozon.kz/search/*",
        "https://*.ozon.kz/search-by-image*"
      ],
      "js": [
        "content/shared-utils.js",
        "content/collector/task-queue.js",
        "content/collector/db.js",
        "content/collector/auto-scroller.js",
        "content/collector/keyword-pilot.js",
        "content/collector/anti-ban.js",
        "content/collector/panel.js",
        "lib/sidebar-section-toggle.js",
        "content/ozon-data-panel.js"
      ],
      "css": [
        "content/ozon-product.css",
        "content/ozon-search.css",
        "content/collector/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://seller.ozon.ru/*"
      ],
      "js": [
        "content/ozon-seller-bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://seller.ozon.ru/app/analytics/competitors/ozon-bestsellers*"
      ],
      "js": [
        "content/ozon-bestsellers-hook.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://seller.ozon.ru/app/analytics*"
      ],
      "js": [
        "content/ozon-premium-hook.js"
      ],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "http://localhost:3001/*"
      ],
      "js": [
        "content/sync-auth.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "batch-upload/*",
        "lib/*",
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "key": ""
}