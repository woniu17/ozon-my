{
  "manifest_version": 3,
  "name": "XY Ozon 模拟手动跟卖 Demo",
  "version": "0.13.31.1",
  "description": "从原项目抽离的模拟手动上架(viaPortal=true)流程。对接 erp-backend-lite 真实后端,Phase 3 变体预取与 Phase 7 轮询真实访问 seller.ozon.ru。",
  "permissions": ["storage", "cookies", "scripting", "activeTab", "contextMenus"],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "https://www.ozon.ru/*",
    "https://ozon.ru/*",
    "https://ozon.kz/*",
    "https://*.ozon.kz/*",
    "https://seller.ozon.ru/*",
    "https://*.1688.com/*",
    "https://s.1688.com/*",
    "https://item.jd.com/*",
    "https://item.m.jd.com/*",
    "https://pifa.pinduoduo.com/*",
    "https://item.taobao.com/*",
    "https://detail.tmall.com/*",
    "https://*.tmall.com/*",
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*",
    "https://*.amazon.fr/*",
    "https://*.amazon.it/*",
    "https://*.amazon.es/*",
    "https://*.amazon.nl/*",
    "https://*.amazon.pl/*",
    "https://*.amazon.se/*",
    "https://*.amazon.com.tr/*",
    "https://*.amazon.ae/*",
    "https://*.amazon.sa/*",
    "https://*.amazon.eg/*",
    "https://*.amazon.in/*",
    "https://*.amazon.co.jp/*",
    "https://*.amazon.com.au/*",
    "https://*.amazon.sg/*",
    "https://*.amazon.ca/*",
    "https://*.amazon.com.mx/*",
    "https://*.amazon.com.br/*",
    "https://*.wildberries.ru/*",
    "https://*.temu.com/*",
    "https://*.mercadolibre.com/*",
    "https://*.mercadolibre.com.ar/*",
    "https://*.mercadolibre.com.br/*",
    "https://*.mercadolibre.com.mx/*",
    "https://*.mercadolibre.cl/*",
    "https://*.mercadolibre.com.co/*",
    "https://*.mercadolibre.com.pe/*",
    "https://*.mercadolibre.com.uy/*",
    "https://*.mercadolibre.com.ec/*",
    "https://market.yandex.ru/*",
    "https://market.yandex.by/*",
    "https://market.yandex.kz/*",
    "https://market.yandex.com/*",
    "https://shein.com/*",
    "https://*.shein.com/*",
    "https://shein.co.uk/*",
    "https://shein.com.br/*",
    "https://shein.com.mx/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "XY Ozon 跟卖 Demo"
  },
  "content_scripts": [
    {
      "matches": ["https://www.ozon.ru/*", "https://ozon.ru/*", "https://ozon.kz/*", "https://*.ozon.kz/*"],
      "js": [
        "src/lib/content-copy.js",
        "src/lib/title-quality.js",
        "src/content/product-extractor.js",
        "src/content/variant-expander.js",
        "src/content/follow-sell-panel.js",
        "src/content/action-bar.js",
        "src/content/sidebar-card.js",
        "src/content/collector-panel.js",
        "src/content/data-panel.js",
        "src/content/pricing-panel.js",
        "src/content/keyword-panel.js",
        "src/content/recommend-panel.js",
        "src/content/seller-list-modal.js",
        "src/content/content.js"
      ],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://detail.1688.com/offer/*"],
      "js": ["src/content/alibaba-1688-panel.js", "src/content/ai-wizard-modal.js"],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://item.jd.com/*",
        "https://item.m.jd.com/*",
        "https://pifa.pinduoduo.com/*",
        "https://item.taobao.com/*",
        "https://detail.tmall.com/*",
        "https://*.tmall.com/*",
        "https://*.wildberries.ru/*",
        "https://*.temu.com/*",
        "https://market.yandex.ru/*",
        "https://shein.com/*",
        "https://*.shein.com/*"
      ],
      "js": ["src/content/cn-source-panel.js"],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://seller.ozon.ru/app/analytics*"],
      "js": ["src/content/premium-xray-panel.js"],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "src/popup/icon.png",
    "48": "src/popup/icon.png",
    "128": "src/popup/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/batch-upload/*"],
      "matches": ["https://www.ozon.ru/*", "https://ozon.ru/*", "https://ozon.kz/*", "https://*.ozon.kz/*"]
    }
  ]
}
